# Sentinel environment — copy to `.env` (which is gitignored) and fill in.
#   cp .env.example .env
# Never commit a real key. `.env` is already in .gitignore.

# Etherscan API key (free, Ethereum mainnet) — enables live approval discovery.
# Get one at https://etherscan.io/myapikey
ETHERSCAN_KEY=your_etherscan_key_here

# Optional — Alchemy key (free tier) for higher-rate eth_call verification.
# ALCHEMY_KEY=your_alchemy_key_here

# Optional — custom JSON-RPC endpoint (overrides the built-in public RPCs).
# RPC_URL=https://your-rpc-endpoint

# Port for the local web app.
PORT=7702
